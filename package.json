{
  "name": "@coral-save/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build-save-parser": "nx run save_parser:build-wasm",
    "build-editor-pages": "node tools/pages/build-editor-pages.mjs",
    "commit": "git-cz",
    "prepare": "husky",
    "test-build-editor-pages-script": "node tools/pages/build-editor-pages.test.mjs",
    "test-editor-routes": "ts-node --project apps/editor/tsconfig.editor.json -r tsconfig-paths/register --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' apps/editor/src/app/coral-island-editor/coral-island-editor.routes.test.ts",
    "test-editor-explorer": "ts-node --project apps/editor/tsconfig.editor.json -r tsconfig-paths/register --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' apps/editor/src/app/coral-island-editor/explorer/save-explorer.model.test.ts",
    "test-save-parser": "nx run save_parser:test"
  },
  "private": true,
  "lint-staged": {
    "*": [
      "prettier --ignore-unknown --write"
    ]
  },
  "config": {
    "editorPagesBaseHref": "/coral-island-save-editor/",
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "@angular/build": {
      "undici": "7.28.0"
    },
    "vite": {
      "esbuild": "0.28.1"
    }
  },
  "dependencies": {
    "@angular/animations": "21.2.17",
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/material": "21.2.14",
    "@angular/platform-browser": "21.2.17",
    "@angular/router": "21.2.17",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "21.2.17",
    "@angular-devkit/schematics": "21.2.17",
    "@angular/build": "21.2.17",
    "@angular/cli": "21.2.17",
    "@angular/compiler-cli": "21.2.17",
    "@angular/language-service": "21.2.17",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.8.0",
    "@monodon/rust": "^3.0.0",
    "@nx/angular": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@schematics/angular": "21.2.17",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.23",
    "@types/node": "18.16.9",
    "@typescript-eslint/utils": "^8.33.1",
    "angular-eslint": "21.4.0",
    "autoprefixer": "^10.4.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "nx": "23.0.1",
    "postcss": "^8.4.5",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.33.1"
  }
}
